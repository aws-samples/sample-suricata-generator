    "version": "1.0.0",
    "last_updated": "2026-03-11",
    "description": "Mapping file for Palo Alto Networks to Suricata rule conversion. Contains application-to-protocol mappings, domain-based application mappings, URL category mappings, default ports for application-default service resolution, ISO 3166-1 country codes for GeoIP detection, and built-in PAN-OS service definitions.",
    "panos_versions_tested": ["10.1", "10.2", "11.0", "11.1"],

    "protocol_mappings": {
        "_description": "Tier 1: Direct PA application to Suricata protocol mappings (high confidence). 'suricata_protocol' is the Suricata rule protocol keyword. 'default_port' is used when service is 'application-default'. 'app_layer' indicates if Suricata has app-layer detection (port can be 'any'). 'deny_action' (optional) specifies what Suricata action to use when PA action is 'deny' — PA deny behavior varies by application (TCP apps send RST, UDP apps send ICMP unreachable). Values: 'reject' (sends RST/ICMP unreachable, like PA deny) or 'drop' (silent drop). If absent, defaults to 'drop'.",
        "ssl": {
            "suricata_protocol": "tls",
            "default_port": "443",
            "app_layer": true,
            "deny_action": "reject",
            "description": "SSL/TLS encrypted traffic"
        },
        "web-browsing": {
            "suricata_protocol": "http",
            "default_port": "80",
            "app_layer": true,
            "deny_action": "reject",
            "description": "HTTP web browsing"
        },
        "dns": {
            "suricata_protocol": "dns",
            "default_port": "53",
            "app_layer": true,
            "deny_action": "drop",
            "description": "Domain Name System"
        },
        "ssh": {
            "suricata_protocol": "ssh",
            "default_port": "22",
            "app_layer": true,
            "deny_action": "reject",
            "description": "Secure Shell"
        },
        "ftp": {
